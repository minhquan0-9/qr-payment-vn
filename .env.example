# ===== Tài khoản nhận tiền (sinh QR VietQR) =====
# BIN code của ngân hàng - tra tại https://api.vietqr.io/v2/banks
# 970422 = MB Bank, 970436 = Vietcombank, 970418 = BIDV, 970415 = VietinBank
BANK_BIN=970422
BANK_ACCOUNT_NUMBER=YOUR_ACCOUNT_NUMBER
BANK_ACCOUNT_NAME=YOUR_NAME

# ===== MB Bank credentials (cho worker poll) =====
# Đăng nhập tự động vào app MB Bank để lấy lịch sử giao dịch.
# CẢNH BÁO: dùng credentials cá nhân của anh. Vi phạm ToS NH; dùng tài khoản
# riêng dành cho web bán hàng, KHÔNG dùng tài khoản chính.
MB_USERNAME=YOUR_MB_USERNAME_OR_PHONE
MB_PASSWORD=YOUR_MB_PASSWORD
# Số tài khoản MB cần track. Để rỗng = track tất cả tài khoản đăng ký dưới user này.
MB_ACCOUNT_NO=

# Mỗi bao nhiêu giây poll 1 lần. 5-10s là hợp lý; thấp hơn dễ bị MB rate-limit.
POLL_INTERVAL_SECONDS=10
# Lùi về quá khứ bao nhiêu phút khi poll lần đầu (tránh miss giao dịch lúc khởi động worker)
POLL_LOOKBACK_MINUTES=30

# ===== Database =====
# Local dev có thể dùng SQLite: sqlite+aiosqlite:///./payments.db
# Production nên dùng Postgres: postgresql+asyncpg://user:password@host:5432/db
DATABASE_URL=postgresql+asyncpg://payment:payment@postgres:5432/payments

# ===== App =====
APP_HOST=0.0.0.0
APP_PORT=8000
ORDER_EXPIRES_MINUTES=15
CORS_ORIGINS=*

# ===== Feature flags =====
# Bật SMS webhook (kèm secret) làm fallback nếu cần
ENABLE_SMS_WEBHOOK=false
WEBHOOK_SECRET=change_me_in_production
# Bật worker poll bên trong FastAPI app (thay vì chạy container riêng)
ENABLE_IN_PROCESS_POLLER=false
