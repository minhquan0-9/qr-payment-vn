# ===== Tài khoản nhận tiền (sinh QR VietQR) =====
# BIN code của ngân hàng - tra tại https://api.vietqr.io/v2/banks
# 970422 = MB Bank, 970416 = ACB, 970423 = TPBank, 970436 = Vietcombank
BANK_BIN=970422
BANK_ACCOUNT_NUMBER=YOUR_ACCOUNT_NUMBER
BANK_ACCOUNT_NAME=YOUR_NAME

# ===== Worker bank type =====
# Mỗi worker container chỉ phục vụ 1 NH. Đặt cùng giá trị với --profile khi
# chạy docker compose. Một trong: mb / acb / tpb.
BANK_TYPE=mb

# ===== MB Bank (worker poll mbbank-lib) =====
# CẢNH BÁO: dùng credentials cá nhân; vi phạm ToS NH; dùng tài khoản riêng cho
# web bán hàng, KHÔNG dùng tài khoản chính.
MB_USERNAME=YOUR_MB_USERNAME_OR_PHONE
MB_PASSWORD=YOUR_MB_PASSWORD
# Để rỗng = track tất cả tài khoản đăng ký dưới user này
MB_ACCOUNT_NO=

# ===== ACB (worker poll makky-acb-api) =====
# CẢNH BÁO: lib unofficial, dùng tài khoản riêng cho web bán hàng.
ACB_USERNAME=
ACB_PASSWORD=
ACB_ACCOUNT_NO=

# ===== TPBank (worker poll ebank.tpb.vn) =====
# Setup 1 lần đầu: xem docs/tpbank-setup.md
#   1. Đăng nhập web banking trên 1 trình duyệt (xác minh khuôn mặt)
#   2. F12 → Console: localStorage.deviceId → copy vào TPB_DEVICE_ID
TPB_USERNAME=
TPB_PASSWORD=
TPB_DEVICE_ID=
TPB_ACCOUNT_ID=

# ===== Poller =====
# Mỗi bao nhiêu giây poll 1 lần. 5-10s là hợp lý; thấp hơn dễ bị NH rate-limit.
POLL_INTERVAL_SECONDS=10
# Lùi về quá khứ bao nhiêu phút khi poll lần đầu (tránh miss giao dịch lúc khởi động worker)
POLL_LOOKBACK_MINUTES=30

# ===== Database =====
# Local dev có thể dùng SQLite: sqlite+aiosqlite:///./payments.db
# Production nên dùng Postgres: postgresql+asyncpg://user:password@host:5432/db
DATABASE_URL=postgresql+asyncpg://payment:payment@postgres:5432/payments

# ===== App =====
APP_HOST=0.0.0.0
APP_PORT=8000
ORDER_EXPIRES_MINUTES=15
CORS_ORIGINS=*

# ===== Feature flags =====
# Bật SMS webhook (kèm secret) làm fallback nếu cần
ENABLE_SMS_WEBHOOK=false
WEBHOOK_SECRET=change_me_in_production
# Bật worker poll bên trong FastAPI app (thay vì chạy container riêng) — bank dùng từ BANK_TYPE
ENABLE_IN_PROCESS_POLLER=false
