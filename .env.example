# ===== Bank account nhận tiền (sinh QR VietQR) =====
# BIN code của ngân hàng - tra tại https://api.vietqr.io/v2/banks
# Ví dụ: 970436 = Vietcombank, 970422 = MB Bank, 970418 = BIDV, 970415 = VietinBank
BANK_BIN=YOUR_BANK_BIN
BANK_ACCOUNT_NUMBER=YOUR_ACCOUNT_NUMBER
BANK_ACCOUNT_NAME=YOUR_NAME
# Mã viết tắt ngân hàng - dùng để chọn parser SMS phù hợp
# Một trong: VCB, MB, BIDV, VTB, ACB, TCB, TPB, STB, AGR, GENERIC
BANK_CODE=GENERIC

# ===== Database =====
# Local dev có thể dùng SQLite: sqlite+aiosqlite:///./payments.db
# Production nên dùng Postgres: postgresql+asyncpg://user:password@localhost:5432/payments
DATABASE_URL=sqlite+aiosqlite:///./payments.db

# ===== Webhook security =====
# Secret token để xác thực Android SMS forwarder gửi về backend.
# Sinh ngẫu nhiên: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=change_me_in_production

# ===== App =====
APP_HOST=0.0.0.0
APP_PORT=8000
# Thời gian sống của 1 đơn hàng (phút) trước khi tự động hết hạn
ORDER_EXPIRES_MINUTES=15
# CORS cho frontend bán hàng - dấu phẩy để phân tách nhiều origin, * cho phép tất cả
CORS_ORIGINS=*
